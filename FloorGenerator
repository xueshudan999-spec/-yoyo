using UnityEngine;
using UnityEditor;
using System.Collections.Generic;

public class FloorGenerator : EditorWindow
{
    private int gridX = 12;
    private int gridZ = 12;
    private bool centerAtOrigin = true;
    private GameObject sourceObject;

    // 自动检测出来的尺寸
    private Vector3 autoTileSize = Vector3.one;
    private bool sizeDetected = false;

    [MenuItem("Tools/生成地面 %g", false, 100)]
    public static void ShowWindow()
    {
        FloorGenerator window = GetWindow<FloorGenerator>("地面生成工具");
        window.minSize = new Vector2(360, 300);
        window.Show();
    }

    private void OnEnable()
    {
        ReadSelection();
    }

    private void OnSelectionChange()
    {
        ReadSelection();
        Repaint();
    }

    private void ReadSelection()
    {
        sourceObject = Selection.activeGameObject;
        if (sourceObject != null)
            DetectTileSize(sourceObject);
    }

    /// <summary>
    /// 自动检测地板实际尺寸（读取 Mesh 或 Renderer 的 bounds，或 localScale）
    /// </summary>
    private void DetectTileSize(GameObject obj)
    {
        sizeDetected = false;

        // 方法1：从 MeshFilter 取 Mesh 的 bounds（单位是本地坐标，不受缩放影响）
        MeshFilter mf = obj.GetComponent<MeshFilter>();
        if (mf != null && mf.sharedMesh != null)
        {
            Bounds meshBounds = mf.sharedMesh.bounds;
            // 乘以世界缩放才是世界尺寸
            Vector3 scale = obj.transform.lossyScale;
            autoTileSize = new Vector3(
                meshBounds.size.x * scale.x,
                meshBounds.size.y * scale.y,
                meshBounds.size.z * scale.z
            );
            sizeDetected = true;
            return;
        }

        // 方法2：从 Renderer 的包围盒取（最准，但需要场景中实例化）
        Renderer renderer = obj.GetComponent<Renderer>();
        if (renderer != null)
        {
            autoTileSize = renderer.bounds.size;
            sizeDetected = true;
            return;
        }

        // 方法3：退回到 localScale
        autoTileSize = obj.transform.localScale;
        sizeDetected = true;
    }

    private void OnGUI()
    {
        GUILayout.Space(10);

        GUIStyle titleStyle = new GUIStyle(EditorStyles.boldLabel)
        {
            fontSize = 14,
            alignment = TextAnchor.MiddleCenter
        };
        GUILayout.Label("🧱 地板拼接生成器", titleStyle);
        GUILayout.Space(8);

        // ── 源对象 ──
        EditorGUILayout.BeginHorizontal();
        EditorGUILayout.PrefixLabel("源地板");
        GameObject prev = sourceObject;
        sourceObject = EditorGUILayout.ObjectField(sourceObject, typeof(GameObject), true) as GameObject;
        EditorGUILayout.EndHorizontal();

        if (sourceObject == null)
        {
            EditorGUILayout.HelpBox("请在场景中选中一个地板对象。", MessageType.Warning);
        }
        else
        {
            EditorGUILayout.HelpBox($"已选择: {sourceObject.name}", MessageType.Info);

            // 显示检测到的尺寸
            if (sizeDetected)
            {
                EditorGUILayout.LabelField($"检测尺寸: {autoTileSize.x:F2} × {autoTileSize.y:F2} × {autoTileSize.z:F2}",
                    EditorStyles.miniLabel);
            }

            float previewW = gridX * autoTileSize.x;
            float previewL = gridZ * autoTileSize.z;
            EditorGUILayout.LabelField($"预计生成范围: {previewW:F1} × {previewL:F1} 米");
        }

        GUILayout.Space(6);

        // ── 参数 ──
        gridX = EditorGUILayout.IntField("X 轴数量", gridX);
        gridZ = EditorGUILayout.IntField("Z 轴数量", gridZ);
        if (gridX < 1) gridX = 1;
        if (gridZ < 1) gridZ = 1;

        EditorGUILayout.LabelField($"总块数: {gridX} × {gridZ} = {gridX * gridZ} 块", EditorStyles.miniLabel);

        centerAtOrigin = EditorGUILayout.Toggle("居中于原点", centerAtOrigin);

        GUILayout.Space(10);

        // ── 生成按钮 ──
        GUI.enabled = sourceObject != null;
        if (GUILayout.Button($"生成 {gridX}×{gridZ} 地面 ({gridX * gridZ} 块)", GUILayout.Height(40)))
        {
            GenerateFloor();
        }
        GUI.enabled = true;

        GUILayout.Space(4);

        if (GUILayout.Button("删除已生成的地面"))
        {
            DeleteGeneratedFloor();
        }

        GUILayout.FlexibleSpace();
        EditorGUILayout.HelpBox(
            "生成时会有进度条，不会卡死编辑器。\n所有地板静态化，运行时不生成任何东西。",
            MessageType.Info);

        EditorGUILayout.HelpBox(
            $"当前地板实际尺寸: {(sizeDetected ? $"{autoTileSize.x:F2} × {autoTileSize.z:F2} 米" : "未检测")}",
            MessageType.None);
    }

    private void GenerateFloor()
    {
        if (sourceObject == null)
        {
            EditorUtility.DisplayDialog("错误", "请先选择一个地板对象。", "确定");
            return;
        }

        // 再次检测尺寸
        DetectTileSize(sourceObject);
        Vector3 tileSize = autoTileSize;
        float tileStepX = tileSize.x;
        float tileStepZ = tileSize.z;

        if (tileStepX <= 0f || tileStepZ <= 0f)
        {
            EditorUtility.DisplayDialog("错误", "无法获取地板尺寸，请检查模型。", "确定");
            return;
        }

        int totalCount = gridX * gridZ;
        float totalW = gridX * tileStepX;
        float totalL = gridZ * tileStepZ;

        // ── 询问确认 ──
        if (!EditorUtility.DisplayDialog(
                "确认生成",
                $"将生成 {gridX}×{gridZ} = {totalCount} 块地板\n" +
                $"单块尺寸: {tileStepX:F2} × {tileStepZ:F2} 米\n" +
                $"总范围: {totalW:F1} × {totalL:F1} 米\n\n" +
                $"继续吗？",
                "生成", "取消"))
            return;

        // ── 用一个 Undo 组包裹全部操作 ──
        Undo.IncrementCurrentGroup();
        int groupIndex = Undo.GetCurrentGroup();

        // ── 父对象 ──
        string parentName = $"[Floor] {gridX}×{gridZ} ({totalW:F1}x{totalL:F1}m)";
        GameObject parent = new GameObject(parentName);
        Undo.RegisterCreatedObjectUndo(parent, "Generate Floor");
        parent.transform.position = Vector3.zero;
        parent.isStatic = true;

        // ── 计算起始位置 ──
        Vector3 startPos;
        if (centerAtOrigin)
        {
            startPos = new Vector3(
                -totalW / 2f + tileStepX / 2f,
                sourceObject.transform.position.y,
                -totalL / 2f + tileStepZ / 2f
            );
        }
        else
        {
            startPos = sourceObject.transform.position;
        }

        // ── 记录源对象是否在场景中 ──
        bool sourceIsSceneObject = !EditorUtility.IsPersistent(sourceObject);

        // ── 开始生成（带进度条，不卡编辑器） ──
        int processed = 0;
        for (int x = 0; x < gridX; x++)
        {
            for (int z = 0; z < gridZ; z++)
            {
                // ▸ 进度条（让编辑器保持响应）
                float progress = (float)processed / totalCount;
                string info = $"正在生成... ({x + 1},{z + 1})  {processed + 1}/{totalCount}";
                if (EditorUtility.DisplayCancelableProgressBar("生成地面", info, progress))
                {
                    // 用户点了取消
                    EditorUtility.ClearProgressBar();
                    Undo.PerformUndo();
                    Debug.LogWarning("地面生成已取消");
                    return;
                }

                Vector3 pos = new Vector3(
                    startPos.x + x * tileStepX,
                    sourceObject.transform.position.y,
                    startPos.z + z * tileStepZ
                );

                GameObject tile;
                if (x == 0 && z == 0 && sourceIsSceneObject)
                {
                    // 第一块 = 源对象本身
                    tile = sourceObject;
                    tile.transform.position = pos;
                    tile.transform.SetParent(parent.transform);
                    tile.isStatic = true;
                    tile.name = $"{sourceObject.name}_({x},{z})";
                }
                else
                {
                    tile = (GameObject)PrefabUtility.InstantiatePrefab(sourceObject, parent.transform);
                    if (tile == null)
                    {
                        // 不是预制体，用普通 Instantiate
                        tile = Instantiate(sourceObject, pos, sourceObject.transform.rotation, parent.transform);
                    }
                    else
                    {
                        tile.transform.position = pos;
                        tile.transform.rotation = sourceObject.transform.rotation;
                    }
                    tile.name = $"{sourceObject.name}_({x},{z})";
                    tile.isStatic = true;
                }

                // 给地板加上碰撞器（CharacterController 需要）
                EnsureTileCollider(tile);

                processed++;
            }
        }

        EditorUtility.ClearProgressBar();

        // ── 折叠 Undo ──
        Undo.CollapseUndoOperations(groupIndex);

        // ── 选中父对象 ──
        Selection.activeGameObject = parent;

        Debug.Log($"地面生成完成: {gridX}×{gridZ} = {totalCount} 块, 范围 {totalW:F1}×{totalL:F1} 米");
    }

    private void DeleteGeneratedFloor()
    {
        GameObject[] allObjects = FindObjectsOfType<GameObject>(true);
        List<GameObject> toDelete = new List<GameObject>();

        foreach (GameObject obj in allObjects)
        {
            if (obj.name.StartsWith("[Floor]") && obj.scene.name != null)
            {
                toDelete.Add(obj);
            }
        }

        if (toDelete.Count == 0)
        {
            EditorUtility.DisplayDialog("提示", "没有找到可删除的地面对象。", "确定");
            return;
        }

        if (!EditorUtility.DisplayDialog("确认删除",
                $"将删除 {toDelete.Count} 个地面对象及其子物体，\n确定吗？",
                "删除", "取消"))
            return;

        Undo.IncrementCurrentGroup();
        foreach (GameObject obj in toDelete)
        {
            Undo.DestroyObjectImmediate(obj);
        }

        Debug.Log($"🗑️ 已删除 {toDelete.Count} 个地面对象。");
    }

    /// <summary>
    /// 确保地板有碰撞器，否则 CharacterController / Rigidbody 会穿过去
    /// </summary>
    private void EnsureTileCollider(GameObject tile)
    {
        // 已有碰撞器就不重复加
        if (tile.GetComponent<Collider>() != null) return;

        MeshCollider collider = tile.AddComponent<MeshCollider>();
        collider.sharedMesh = null; // 强制从 MeshFilter 里读
        collider.convex = false;

        // 手动刷新一下 Mesh
        MeshFilter mf = tile.GetComponent<MeshFilter>();
        if (mf != null && mf.sharedMesh != null)
        {
            collider.sharedMesh = mf.sharedMesh;
        }
    }
}
